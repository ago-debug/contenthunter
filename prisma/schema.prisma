generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Catalog {
  id            Int            @id @default(autoincrement())
  name          String
  createdAt     DateTime       @default(now())
  
  // Repository Settings
  imageFolderPath String?      @db.Text
  status          String       @default("draft") // draft, processing, staging, completed
  
  templateId    Int?
  template      Template?      @relation(fields: [templateId], references: [id])
  
  pdfs          CatalogPdf[]
  entries       CatalogEntry[]
  searchSources SearchSource[]
  pages         PdfPage[]
  stagingProducts StagingProduct[]

  lastListinoName String?      @db.Text

  @@index([templateId], map: "Catalog_templateId_fkey")
}

model CatalogPdf {
  id        Int      @id @default(autoincrement())
  catalogId Int
  fileName  String
  filePath  String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId])
}

model CatalogEntry {
  id        Int      @id @default(autoincrement())
  catalogId Int
  productId Int

  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([catalogId, productId])
  @@index([productId], map: "CatalogEntry_productId_fkey")
  @@index([catalogId], map: "CatalogEntry_catalogId_fkey")
}

model SearchSource {
  id        Int      @id @default(autoincrement())
  catalogId Int
  url       String   @db.LongText
  label     String?
  createdAt DateTime @default(now())
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId], map: "SearchSource_catalogId_fkey")
}

model Template {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  catalogs  Catalog[]
  rules     Rule[]
}

model Rule {
  id         Int      @id @default(autoincrement())
  templateId Int
  fieldName  String
  regex      String?
  zoneX      Float?
  zoneY      Float?
  zoneWidth  Float?
  zoneHeight Float?
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId], map: "Rule_templateId_fkey")
}

model Product {
  id             Int            @id @default(autoincrement())
  sku            String         @unique
  parentSku      String?
  ean            String?        @unique
  
  brand            String?
  brandId          Int?
  brandRef         Brand?    @relation(fields: [brandId], references: [id])
  
  category         String?
  categoryId       Int?
  subCategoryId    Int?
  subSubCategoryId Int?
  
  categoryRef       Category? @relation("ProductCategory", fields: [categoryId], references: [id])
  subCategoryRef    Category? @relation("ProductSubCategory", fields: [subCategoryId], references: [id])
  subSubCategoryRef Category? @relation("ProductSubSubCategory", fields: [subSubCategoryId], references: [id])
  
  texts          ProductText[]
  prices         ProductPrice[]
  extraFields    ProductExtra[]
  images         ProductImage[]
  bulletPointRefs BulletPoint[]
  catalogs       CatalogEntry[]
  history        ProductHistory[]
  tags           ProductTag[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([sku])
  @@index([brandId])
}

model ProductHistory {
  id        Int      @id @default(autoincrement())
  productId Int
  data      Json
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductText {
  id             Int      @id @default(autoincrement())
  productId      Int
  language       String   @default("it")
  
  title          String?
  description    String?  @db.Text
  docDescription String?  @db.Text
  bulletPoints   String?  @db.Text
  seoAiText      String?  @db.Text

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, language])
  @@index([productId], map: "ProductText_productId_fkey")
}

model ProductPrice {
  id             Int      @id @default(autoincrement())
  productId      Int
  listName       String   @default("default")
  price          Float
  currency       String   @default("EUR")

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, listName])
  @@index([productId], map: "ProductPrice_productId_fkey")
}

model ProductExtra {
  id             Int      @id @default(autoincrement())
  productId      Int
  key            String
  value          String   @db.Text

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@index([productId], map: "ProductExtra_productId_fkey")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  imageUrl  String   @db.LongText
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "ProductImage_productId_fkey")
}

model PdfPage {
  id        Int      @id @default(autoincrement())
  catalogId Int
  pageNumber Int
  text      String   @db.LongText
  imageUrl  String   @db.LongText
  subImages String?  @db.LongText // JSON array of extracted image paths
  createdAt DateTime @default(now())
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")

  productsMain   Product[] @relation("ProductCategory")
  productsSub    Product[] @relation("ProductSubCategory")
  productsSubSub Product[] @relation("ProductSubSubCategory")

  @@unique([name, parentId])
}

model Tag {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  
  products  ProductTag[]
}

model ProductTag {
  productId Int
  tagId     Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  logoUrl   String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model BulletPoint {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@index([productId])
}

model StagingProduct {
  id             Int            @id @default(autoincrement())
  catalogId      Int
  catalog        Catalog        @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  
  sku            String         
  parentSku      String?
  ean            String?
  
  brand          String?
  category       String?
  
  texts          StagingProductText[]
  prices         StagingProductPrice[]
  extraFields    StagingProductExtra[]
  images         StagingProductImage[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([catalogId])
  @@index([sku])
}

model StagingProductText {
  id             Int      @id @default(autoincrement())
  stagingProductId Int
  language       String   @default("it")
  
  title          String?
  description    String?  @db.Text
  docDescription String?  @db.Text
  bulletPoints   String?  @db.Text
  seoAiText      String?  @db.Text

  stagingProduct StagingProduct @relation(fields: [stagingProductId], references: [id], onDelete: Cascade)

  @@unique([stagingProductId, language])
}

model StagingProductPrice {
  id             Int      @id @default(autoincrement())
  stagingProductId Int
  listName       String   @default("default")
  price          Float
  currency       String   @default("EUR")

  stagingProduct StagingProduct @relation(fields: [stagingProductId], references: [id], onDelete: Cascade)

  @@unique([stagingProductId, listName])
}

model StagingProductExtra {
  id             Int      @id @default(autoincrement())
  stagingProductId Int
  key            String
  value          String   @db.Text

  stagingProduct StagingProduct @relation(fields: [stagingProductId], references: [id], onDelete: Cascade)

  @@unique([stagingProductId, key])
}

model StagingProductImage {
  id               Int      @id @default(autoincrement())
  stagingProductId Int
  imageUrl         String   @db.LongText
  createdAt        DateTime @default(now())
  stagingProduct   StagingProduct @relation(fields: [stagingProductId], references: [id], onDelete: Cascade)

  @@index([stagingProductId])
}

