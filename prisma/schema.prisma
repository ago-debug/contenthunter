generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Catalog {
  id            Int            @id @default(autoincrement())
  name          String
  filePath      String
  webhookUrl    String?
  templateId    Int?
  createdAt     DateTime       @default(now())
  template      Template?      @relation(fields: [templateId], references: [id])
  entries       CatalogEntry[]
  searchSources SearchSource[]
  pages         PdfPage[]

  @@index([templateId], map: "Catalog_templateId_fkey")
}

model CatalogEntry {
  id        Int      @id @default(autoincrement())
  catalogId Int
  productId Int

  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([catalogId, productId])
  @@index([productId], map: "CatalogEntry_productId_fkey")
  @@index([catalogId], map: "CatalogEntry_catalogId_fkey")
}

model SearchSource {
  id        Int      @id @default(autoincrement())
  catalogId Int
  url       String   @db.LongText
  label     String?
  createdAt DateTime @default(now())
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId], map: "SearchSource_catalogId_fkey")
}

model Template {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  catalogs  Catalog[]
  rules     Rule[]
}

model Rule {
  id         Int      @id @default(autoincrement())
  templateId Int
  fieldName  String
  regex      String?
  zoneX      Float?
  zoneY      Float?
  zoneWidth  Float?
  zoneHeight Float?
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId], map: "Rule_templateId_fkey")
}

model Product {
  id             Int            @id @default(autoincrement())
  sku            String         @unique
  parentSku      String?
  ean            String?        @unique
  
  brand          String?
  category       String?
  
  texts          ProductText[]
  prices         ProductPrice[]
  extraFields    ProductExtra[]
  images         ProductImage[]
  catalogs       CatalogEntry[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([sku])
}

model ProductText {
  id             Int      @id @default(autoincrement())
  productId      Int
  language       String   @default("it")
  
  title          String?
  description    String?  @db.Text
  docDescription String?  @db.Text
  bulletPoints   String?  @db.Text
  seoAiText      String?  @db.Text

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, language])
  @@index([productId], map: "ProductText_productId_fkey")
}

model ProductPrice {
  id             Int      @id @default(autoincrement())
  productId      Int
  listName       String   @default("default")
  price          Float
  currency       String   @default("EUR")

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, listName])
  @@index([productId], map: "ProductPrice_productId_fkey")
}

model ProductExtra {
  id             Int      @id @default(autoincrement())
  productId      Int
  key            String
  value          String   @db.Text

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@index([productId], map: "ProductExtra_productId_fkey")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  imageUrl  String   @db.LongText
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "ProductImage_productId_fkey")
}

model PdfPage {
  id        Int      @id @default(autoincrement())
  catalogId Int
  pageNumber Int
  text      String   @db.LongText
  imageUrl  String   @db.LongText
  subImages String?  @db.LongText // JSON array of extracted image paths
  createdAt DateTime @default(now())
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
